<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">
    <!--
        Added the constraints for entity Trademark.
    -->
    <changeSet id="20240522160735-2" author="jhipster">

        <addForeignKeyConstraint baseColumnNames="lead_id"
                                 baseTableName="trademark"
                                 constraintName="fk_trademark__lead_id"
                                 referencedColumnNames="id"
                                 referencedTableName="lead"
                                 onDelete="CASCADE"
                                 onUpdate="CASCADE"
                                 />

        <addForeignKeyConstraint baseColumnNames="user_id"
                                 baseTableName="trademark"
                                 constraintName="fk_trademark__user_id"
                                 referencedColumnNames="id"
                                 referencedTableName="user_profile"
                                 onDelete="CASCADE"
                                 onUpdate="CASCADE"
                                 />

        <addForeignKeyConstraint baseColumnNames="trademark_plan_id"
                                 baseTableName="trademark"
                                 constraintName="fk_trademark__trademark_plan_id"
                                 referencedColumnNames="id"
                                 referencedTableName="trademark_plan"
                                 onUpdate="CASCADE"
                                 />

        <addForeignKeyConstraint baseColumnNames="trademark_id"
                                 baseTableName="rel_trademark__trademark_classes"
                                 constraintName="fk_rel_trademark__trademark_classes__trademark_id"
                                 referencedColumnNames="id"
                                 referencedTableName="trademark"
                                 />

        <addForeignKeyConstraint baseColumnNames="trademark_classes_id"
                                 baseTableName="rel_trademark__trademark_classes"
                                 constraintName="fk_rel_trademark__trademark_classes__trademark_classes_id"
                                 referencedColumnNames="id"
                                 referencedTableName="trademark_class"
                                 />
    </changeSet>
</databaseChangeLog>
